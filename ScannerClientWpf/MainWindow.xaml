<Window x:Class="ScannerClientWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shared Scanner" Height="760" Width="1160" MinHeight="640" MinWidth="980"
        Background="#F5F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Servidor" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBox x:Name="ServerUrlBox" Grid.Column="1" Height="32" VerticalContentAlignment="Center"/>
                <Button x:Name="TestButton" Grid.Column="2" Content="Testar conexão" Width="130" Height="32" Margin="8,0,0,0" Click="TestButton_Click"/>
                <Button x:Name="RefreshButton" Grid.Column="3" Content="Atualizar scanners" Width="150" Height="32" Margin="8,0,0,0" Click="RefreshButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ScannerCombo" DisplayMemberPath="Name" Height="32"/>
                <ComboBox x:Name="DpiCombo" Grid.Column="1" Width="90" Height="32" Margin="8,0,0,0"/>
                <ComboBox x:Name="ColorModeCombo" Grid.Column="2" Width="150" Height="32" Margin="8,0,0,0"/>
                <ComboBox x:Name="FormatCombo" Grid.Column="3" Width="90" Height="32" Margin="8,0,0,0"/>
                <Button x:Name="ScanButton" Grid.Column="4" Content="Digitalizar" Width="120" Height="32" Margin="8,0,0,0" Click="ScanButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Páginas" FontWeight="SemiBold" Margin="4,0,0,8"/>
                    <ListBox x:Name="PagesList" SelectionChanged="PagesList_SelectionChanged" ItemsSource="{Binding Pages}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding Image}" Width="48" Height="64" Stretch="Uniform"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="#1E232B" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Padding="12">
                <Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Image x:Name="PreviewImage" Stretch="Uniform"/>
                    </ScrollViewer>
                    <TextBlock x:Name="EmptyPreviewText" Text="Nenhuma página digitalizada" Foreground="#D7DCE5"
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="Girar esquerda" Width="120" Height="32" Click="RotateLeft_Click"/>
                <Button Grid.Column="1" Content="Girar direita" Width="120" Height="32" Margin="8,0,0,0" Click="RotateRight_Click"/>
                <Button Grid.Column="2" Content="Remover" Width="90" Height="32" Margin="8,0,0,0" Click="Remove_Click"/>
                <Button Grid.Column="3" Content="Subir" Width="80" Height="32" Margin="8,0,0,0" Click="MoveUp_Click"/>
                <Button Grid.Column="4" Content="Descer" Width="80" Height="32" Margin="8,0,0,0" Click="MoveDown_Click"/>
                <TextBlock x:Name="StatusText" Grid.Column="5" VerticalAlignment="Center" Margin="12,0" Foreground="#344054"/>
                <Button Grid.Column="6" Content="Salvar" Width="110" Height="32" FontWeight="SemiBold" Click="Save_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
