<Window x:Class="ScannerClientWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PScanner Client" Icon="Assets/ScannerClient.ico" Height="760" Width="1160" MinHeight="640" MinWidth="980"
        Background="#F5F6F8">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#BFC7D5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="ButtonIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,7,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Servidor" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBox x:Name="ServerUrlBox" Grid.Column="1" Height="32" VerticalContentAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Porta" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,8,0"/>
                <TextBox x:Name="DiscoveryPortBox" Grid.Column="3" Width="64" Height="32" VerticalContentAlignment="Center"/>
                <Button x:Name="DiscoverButton" Grid.Column="4" Width="130" Height="32" Margin="8,0,0,0" Click="DiscoverButton_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource ButtonIcon}" Text="&#xE774;"/>
                        <TextBlock Text="Buscar rede"/>
                    </StackPanel>
                </Button>
                <Button x:Name="TestButton" Grid.Column="5" Width="140" Height="32" Margin="8,0,0,0" Click="TestButton_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource ButtonIcon}" Text="&#xE721;"/>
                        <TextBlock Text="Testar conexao"/>
                    </StackPanel>
                </Button>
                <Button x:Name="RefreshButton" Grid.Column="6" Width="165" Height="32" Margin="8,0,0,0" Click="RefreshButton_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource ButtonIcon}" Text="&#xE72C;"/>
                        <TextBlock Text="Atualizar scanners"/>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Row="1" Text="Encontrados" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,8,8,0"
                           Visibility="{Binding ElementName=DiscoveredServersCombo, Path=Visibility}"/>
                <ComboBox x:Name="DiscoveredServersCombo" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="6" Height="32" Margin="0,8,0,0"
                          DisplayMemberPath="DisplayName" SelectionChanged="DiscoveredServersCombo_SelectionChanged"
                          Visibility="Collapsed"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ScannerCombo" DisplayMemberPath="Name" Height="32" SelectionChanged="ScannerCombo_SelectionChanged"/>
                <ComboBox x:Name="DpiCombo" Grid.Column="1" Width="90" Height="32" Margin="8,0,0,0"/>
                <ComboBox x:Name="ColorModeCombo" Grid.Column="2" Width="150" Height="32" Margin="8,0,0,0"/>
                <ComboBox x:Name="FormatCombo" Grid.Column="3" Width="90" Height="32" Margin="8,0,0,0"/>
                <Button x:Name="ScanButton" Grid.Column="4" Width="130" Height="32" Margin="8,0,0,0" Click="ScanButton_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource ButtonIcon}" Text="&#xE8A5;"/>
                        <TextBlock Text="Digitalizar"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Paginas" FontWeight="SemiBold" Margin="4,0,0,8"/>
                    <ListBox x:Name="PagesList" SelectionChanged="PagesList_SelectionChanged" ItemsSource="{Binding Pages}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding Image}" Width="48" Height="64" Stretch="Uniform"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="#1E232B" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Padding="12">
                <Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Image x:Name="PreviewImage" Stretch="Uniform"/>
                    </ScrollViewer>
                    <TextBlock x:Name="EmptyPreviewText" Text="Nenhuma pagina digitalizada" Foreground="#D7DCE5"
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="White" BorderBrush="#D9DEE7" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Width="130" Height="32" Click="RotateLeft_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource ButtonIcon}" Text="&#xE7AD;"/>
                        <TextBlock Text="Girar esquerda"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Width="120" Height="32" Margin="8,0,0,0" Click="RotateRight_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource ButtonIcon}" Text="&#xE7AD;" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="180"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="Girar direita"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Width="100" Height="32" Margin="8,0,0,0" Click="Remove_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource ButtonIcon}" Text="&#xE74D;"/>
                        <TextBlock Text="Remover"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Width="82" Height="32" Margin="8,0,0,0" Click="MoveUp_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource ButtonIcon}" Text="&#xE74A;"/>
                        <TextBlock Text="Subir"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="4" Width="92" Height="32" Margin="8,0,0,0" Click="MoveDown_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource ButtonIcon}" Text="&#xE74B;"/>
                        <TextBlock Text="Descer"/>
                    </StackPanel>
                </Button>
                <TextBlock x:Name="StatusText" Grid.Column="5" VerticalAlignment="Center" Margin="12,0" Foreground="#344054"/>
                <Button Grid.Column="6" Width="118" Height="32" FontWeight="SemiBold" Click="Save_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource ButtonIcon}" Text="&#xE74E;"/>
                        <TextBlock Text="Salvar"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
